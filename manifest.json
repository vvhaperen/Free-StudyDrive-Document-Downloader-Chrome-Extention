
{
  "manifest_version": 3,
  "name": "StudyDrive Downloader Extension",
  "version": "1.1",
  "description": "A extension to download documents from StudyDrive.",
  "icons": {
    "128": "icon.png"  
  },
  "action": {
    "default_icon": "icon.png",
    "default_title": "Studydrive Downloader — use the green button on the document page"
  },
  "permissions": [
    "downloads"
  ],
  "host_permissions": [
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.studydrive.net/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}

